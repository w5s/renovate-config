{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Default base configuration for all W5s projects.",
  "assigneesFromCodeOwners": true,
  "assigneesSampleSize": 1,
  "automerge": false,
  "dependencyDashboard": true,
  "extends": [
    ":ignoreModulesAndTests",
    ":semanticPrefixFixDepsChoreOthers",
    "helpers:disableTypesNodeMajor",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests",
    "github>w5s/renovate-config//preset/commit",
    "github>w5s/renovate-config//preset/schedule",
    "github>w5s/renovate-config//preset/security",
    "github>w5s/renovate-config//preset/ignore",
    "mergeConfidence:age-confidence-badges",
    "replacements:all",
    "workarounds:all",
    "helpers:githubDigestChangelogs",
    "helpers:goXPackagesChangelogLink",
    "helpers:goXPackagesNameLink"
  ],
  "forkProcessing": "disabled",
  "ignoreUnstable": true,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "prConcurrentLimit": 20,
  "prCreation": "immediate",
  "prHourlyLimit": 0,
  "rangeStrategy": "auto",
  "rebaseWhen": "auto",
  "separateMajorMinor": true,
  "separateMinorPatch": true,
  "updateNotScheduled": true,
  "platformAutomerge": true
}
