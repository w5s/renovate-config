{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Automerge for Package Manager",
  "packageRules": [
    {
      "matchDepTypes": ["packageManager"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": ["pnpm", "npm", "yarn", "bun"],
      "automerge": true
    }
  ]
}
