{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Automerge Node Package Manager",
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["packageManager"],
      "matchUpdateTypes": ["minor", "patch"],
      "automergeType": "branch",
      "automerge": true
    }
  ]
}
